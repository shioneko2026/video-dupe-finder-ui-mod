@page "/results"
@rendermode InteractiveServer
@using System.IO
@inject ScanService Scan
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Results — Video Duplicate Finder</PageTitle>

<div class="results-page">

    @* ── TOOLBAR ── *@
    <div class="results-toolbar">
        <button class="btn-sm" @onclick="Rescan" title="Re-run scan with the same folders">↺ Rescan</button>
        <div class="toolbar-sep"></div>
        <input class="search-box" value="@_search"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty"
               placeholder="Filter by path..." />
        @if (!string.IsNullOrEmpty(_search)) {
            <button @onclick='() => _search = string.Empty' class="btn-sm">✕</button>
        }
        <div class="toolbar-sep"></div>

        @* Smart Select dropdown *@
        <div class="dropdown-wrap">
            <button class="btn-sm" @onclick="() => _autoSelectOpen = !_autoSelectOpen">✦ Smart Select ▾</button>
            @if (_autoSelectOpen) {
                <div class="dropdown-overlay" @onclick="() => _autoSelectOpen = false"></div>
                <div class="dropdown-menu">
                    <div class="dropdown-section">By Quality</div>
                    <button @onclick="() => AutoSelect(AutoSelectMode.LowestQuality)">↓ Lowest quality</button>
                    <button @onclick="() => AutoSelect(AutoSelectMode.SmallestFile)">↓ Smallest file</button>
                    <button @onclick="() => AutoSelect(AutoSelectMode.Oldest)">↑ Oldest (keep newest)</button>
                    <button @onclick="() => AutoSelect(AutoSelectMode.Newest)">↑ Newest (keep oldest)</button>
                    <button @onclick="() => AutoSelect(AutoSelectMode.HundredPercentEqual)">= 100% equal groups</button>
                    <hr />
                    <div class="dropdown-section">By Property</div>
                    <button @onclick="SelectNoAudio">🔇 No audio track</button>
                    <hr />
                    <button @onclick="InvertSelection">⇄ Invert selection</button>
                    <button @onclick="ClearSelection">✕ Deselect all</button>
                </div>
            }
        </div>
        <button class="btn-sm" @onclick="ClearSelection" disabled="@(_flagged.Count == 0)">✕ Unselect All</button>

        <div class="toolbar-spacer"></div>

        @* Clear Resolved — removes groups where only 1 file remains *@
        <button class="btn-sm" @onclick="ClearResolved"
                disabled="@(!Scan.Duplicates.GroupBy(d => d.GroupId).Any(g => g.Count(i => !_deleted.Contains(i.Path)) <= 1))"
                title="Remove groups where all duplicates have been deleted, leaving only one file">Clear Resolved</button>

        @* Grey-out / Remove toggle *@
        <button class="@(_greyOutOnDelete ? "delete-mode-grey" : "delete-mode-remove")" @onclick="() => _greyOutOnDelete = !_greyOutOnDelete"
                title="@(_greyOutOnDelete ? "Deleted files stay visible greyed out in the card" : "Deleted files are removed from the card immediately")">
            @(_greyOutOnDelete ? "On Delete: Grey Out" : "On Delete: Remove")
        </button>

        @* Safety toggle *@
        <button class="@(_safetyOn ? "safety-on" : "safety-off")" @onclick="ToggleSafety">
            @(_safetyOn ? "🛡 Safety: ON" : "⚠ Raw Mode")
        </button>

        @if (_flagged.Count > 0) {
            <span class="selection-count">@_flagged.Count marked for deletion</span>
        }

        <button class="danger" @onclick="DeleteAllFlagged"
                disabled="@(_flagged.Count == 0)">
            🗑 Delete Marked
        </button>
    </div>

    @* ── OPERATION FEEDBACK ── *@
    @if (_operationMsg != null) {
        <div style="padding:6px 14px;flex-shrink:0">
            <div class="@(_operationFailed ? "error-box" : "info-box")">@_operationMsg</div>
        </div>
    }

    @* ── THUMBNAIL RETRIEVAL PROGRESS ── *@
    @if (Scan.State == ScanState.RetrievingThumbnails && Scan.ThumbnailMax > 0) {
        int tpct = (int)(100L * Scan.ThumbnailCurrent / Scan.ThumbnailMax);
        <div style="padding:6px 14px;flex-shrink:0">
            <div class="thumb-progress">
                <span class="spinner"></span>
                Retrieving thumbnails @Scan.ThumbnailCurrent / @Scan.ThumbnailMax
                <div class="progress-bar-track inline-bar">
                    <div class="progress-bar-fill" style="width:@tpct%"></div>
                </div>
            </div>
        </div>
    }

    @* ── RESULTS SCROLL AREA ── *@
    <div class="results-scroll">

        @{
            var allDuplicates = Scan.Duplicates;
            var filteredGroups = allDuplicates
                .GroupBy(d => d.GroupId)
                .Where(g => string.IsNullOrEmpty(_search) ||
                            g.Any(i => i.Path.Contains(_search, StringComparison.OrdinalIgnoreCase)))
                .OrderBy(g => {
                    // Sort groups by the Main folder's (index 0) filename; fallback to any item
                    var mainFolder = Scan.OrderedIncludeList.FirstOrDefault() ?? "";
                    var mainFolderNorm = mainFolder.TrimEnd('\\', '/') + Path.DirectorySeparatorChar;
                    var mainItem = string.IsNullOrEmpty(mainFolder) ? null :
                        g.FirstOrDefault(i => i.Path.StartsWith(mainFolderNorm, StringComparison.OrdinalIgnoreCase));
                    var rep = mainItem ?? g.OrderBy(i => i.Path).First();
                    return Path.GetFileNameWithoutExtension(rep.Path) ?? "";
                })
                .ToList();
        }

        @if (!allDuplicates.Any()) {
            <p style="color:#6b7280;padding:12px 0">No duplicates found. <a href="/">Run a scan</a> first.</p>
        }
        else {
            @foreach (var group in filteredGroups) {
                var items = group.OrderBy(FolderOrder).ThenByDescending(i => i.Similarity).ToList();
                float simPct = items.Max(i => i.Similarity);
                int fileCount = items.Count;
                long totalBytes = items.Sum(i => i.SizeLong);
                var groupFlagged = items.Where(i => _flagged.Contains(i.Path) && !_deleted.Contains(i.Path)).ToList();

                // Precompute color pairing arrays for each field
                var durations = items.Select(i => i.Duration).ToList();
                var sizes     = items.Select(i => i.SizeLong).ToList();
                var dates     = items.Select(i => i.DateCreated.Date).ToList();
                var resolutions = items.Select(i => i.FrameSize ?? "").ToList();
                var formats   = items.Select(i => $"{i.Format}·{i.Fps:F0}·{i.BitRateKbs}").ToList();
                var audios    = items.Select(i => $"{i.AudioFormat}·{i.AudioChannel}·{i.AudioSampleRate}·{i.AudioBitRateKbs}").ToList();
                var folders   = items.Select(i => Path.GetFileName(i.Folder.TrimEnd('\\', '/'))).ToList();

                <div class="group-card" id="group-@group.Key">
                    <div class="group-header">
                        @* Smart Select per group *@
                        <div class="dropdown-wrap">
                            <button class="btn-sm" @onclick="() => ToggleGroupDropdown(group.Key)">✦ Select ▾</button>
                            @if (_openGroupDropdown == group.Key) {
                                <div class="dropdown-overlay" @onclick="() => _openGroupDropdown = Guid.Empty"></div>
                                <div class="dropdown-menu">
                                    <div class="dropdown-section">Flag in this group</div>
                                    <button @onclick="() => { FlagLowestRes(items); _openGroupDropdown = Guid.Empty; }">↓ Lowest resolution</button>
                                    <button @onclick="() => { FlagHighestRes(items); _openGroupDropdown = Guid.Empty; }">↑ Highest resolution</button>
                                    <button @onclick="() => { FlagSmallest(items); _openGroupDropdown = Guid.Empty; }">↓ Smallest file</button>
                                    <button @onclick="() => { FlagLargest(items); _openGroupDropdown = Guid.Empty; }">↑ Largest file</button>
                                    <button @onclick="() => { FlagShortest(items); _openGroupDropdown = Guid.Empty; }">⏱ Shortest duration</button>
                                    <button @onclick="() => { FlagLongest(items); _openGroupDropdown = Guid.Empty; }">⏳ Longest duration</button>
                                    <hr />
                                    <button @onclick="() => { FlagNoAudio(items); _openGroupDropdown = Guid.Empty; }">🔇 No audio track</button>
                                </div>
                            }
                        </div>
                        <button class="btn-sm" @onclick="() => ClearGroupSelection(items)"
                                disabled="@(!items.Any(x => _flagged.Contains(x.Path)))">✕ Unselect</button>
                        <button class="btn-sm" @onclick="() => { FlagNoAudio(items); _openGroupDropdown = Guid.Empty; }"
                                disabled="@(!items.Any(x => !x.IsImage && string.IsNullOrEmpty(x.AudioFormat) && !_deleted.Contains(x.Path)))"
                                title="Flag files in this group that have no audio track">🔇 Select No Audio Track</button>

                        <div class="toolbar-sep"></div>

                        @* Delete Flagged in group *@
                        <button class="btn-sm danger-outline"
                                disabled="@(groupFlagged.Count == 0)"
                                @onclick="() => DeleteFlaggedInGroup(groupFlagged)">
                            🗑 Delete Flagged
                        </button>

                        <div class="toolbar-sep"></div>

                        <span class="similarity-badge">@simPct.ToString("F1")% match</span>
                        <span class="group-meta">@fileCount files · @FormatSize(totalBytes)</span>
                        <div class="group-hspacer"></div>
                        <button class="btn-complete" @onclick="() => CompleteCard(items, group.Key)">✔ Complete and Clear</button>
                        <button class="btn-sm" @onclick="() => CompleteCard(items, group.Key)">Skip</button>
                    </div>

                    @* ── FILE COLUMNS ── *@
                    <div class="files-row">
                        @for (int idx = 0; idx < items.Count; idx++) {
                            var item = items[idx];
                            int i = idx; // capture for lambda
                            bool isFlagged = _flagged.Contains(item.Path);
                            bool isDeleted = _deleted.Contains(item.Path);
                            string colClass = "file-col" + (isFlagged && !isDeleted ? " flagged" : "") + (isDeleted ? " deleted" : "");
                            string title = Path.GetFileNameWithoutExtension(item.Path);
                            string folder = Path.GetFileName(item.Folder.TrimEnd('\\', '/'));

                            <div class="@colClass" @onclick="() => ToggleFlag(item)">
                                @* Thumbnail *@
                                <div class="col-thumb">
                                    <img src="/thumbnail?path=@Uri.EscapeDataString(item.Path)"
                                         alt="thumbnail" loading="lazy"
                                         onerror="this.style.display='none'" />
                                </div>

                                @* Title and folder *@
                                <div class="file-title">@title</div>
                                <div class="file-folder">
                                    📁 <span class="@PairClass(folders[i], folders)">@folder</span>
                                </div>

                                @* Metadata rows *@
                                <div class="data-rows">
                                    <div class="data-row">
                                        <span class="data-label">Duration</span>
                                        <span class="data-value @PairClass(durations[i], durations)">@FormatDuration(item.Duration)</span>
                                    </div>
                                    <div class="data-row">
                                        <span class="data-label">Size</span>
                                        <span class="data-value @PairClass(sizes[i], sizes)">@item.Size</span>
                                    </div>
                                    <div class="data-row">
                                        <span class="data-label">Date</span>
                                        <span class="data-value @PairClass(dates[i], dates)">@item.DateCreated.ToString("yyyy-MM-dd")</span>
                                    </div>
                                    <div class="data-row">
                                        <span class="data-label">Resolution</span>
                                        <span class="data-value @PairClass(resolutions[i], resolutions)">@(item.FrameSize ?? "—")</span>
                                    </div>
                                    @if (!item.IsImage) {
                                        <div class="data-row">
                                            <span class="data-label">Format / FPS / Kbps</span>
                                            <span class="data-value @PairClass(formats[i], formats)">
                                                @item.Format · @item.Fps.ToString("F0")fps · @item.BitRateKbs kbps@(string.IsNullOrEmpty(item.HdrFormat) ? "" : $" · {item.HdrFormat}")
                                            </span>
                                        </div>
                                        <div class="data-row">
                                            <span class="data-label">Audio</span>
                                            <span class="data-value @PairClass(audios[i], audios)">
                                                @(item.AudioFormat ?? "—") · @(item.AudioChannel ?? "—") · @(item.AudioSampleRate > 0 ? $"{item.AudioSampleRate / 1000.0:F0}kHz" : "—") · @item.AudioBitRateKbs kbps
                                            </span>
                                        </div>
                                    }
                                </div>

                                @* Action buttons *@
                                <div class="file-actions">
                                    <button class="btn-flag" @onclick:stopPropagation="true" @onclick="() => ToggleFlag(item)">
                                        @(isFlagged ? "⚑ Flagged" : "☑ Flag")
                                    </button>
                                    @if (!isDeleted) {
                                        <button class="btn-delete" @onclick:stopPropagation="true" @onclick="() => DeleteSingle(item)">
                                            🗑 Delete
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }

    </div>

    @* ── STATUS BAR ── *@
    <footer class="status-bar">
        <span><span class="status-dot dot-blue"></span>@filteredGroups.Count groups</span>
        <span><span class="status-dot dot-red"></span>@(filteredGroups.SelectMany(g => g).Count() - filteredGroups.SelectMany(g => g).Count(i => _deleted.Contains(i.Path))) files remaining</span>
        <span><span class="status-dot dot-green"></span>@FormatSize(filteredGroups.SelectMany(g => g).Where(i => _deleted.Contains(i.Path)).Sum(i => i.SizeLong)) reclaimed</span>
        <div style="flex:1"></div>
        @if (_flagged.Count > 0) {
            <span style="color:#d97706;font-weight:600">@_flagged.Count flagged for deletion</span>
        }
    </footer>

</div>

@* ── SAFETY MODAL ── *@
@if (_showRawModal) {
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:500;display:flex;align-items:center;justify-content:center">
        <div style="background:#fff;border-radius:10px;padding:28px;max-width:380px;width:90%;box-shadow:0 24px 64px rgba(0,0,0,0.2)">
            <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:8px">⚠ Disable Safety?</div>
            <div style="font-size:13px;color:#6b7280;line-height:1.55;margin-bottom:22px">
                Raw Mode skips all confirmation dialogs. Deletions are instant and sent directly to the Recycle Bin with no prompt.
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button @onclick="() => _showRawModal = false">Stay Safe</button>
                <button class="danger" @onclick="GoRaw">Go Raw</button>
            </div>
        </div>
    </div>
}

@code {
    // ── State
    string _search = string.Empty;
    readonly HashSet<string> _flagged = new();
    readonly HashSet<string> _deleted = new();
    bool _safetyOn = true;
    bool _greyOutOnDelete = true;
    bool _showRawModal = false;
    string? _operationMsg;
    bool _operationFailed;
    bool _autoSelectOpen;
    Guid _openGroupDropdown = Guid.Empty;

    // Groups computed in markup — also needed in status bar footer
    List<IGrouping<Guid, DuplicateItem>> filteredGroups = new();

    protected override void OnInitialized() =>
        Scan.StateChanged += OnStateChanged;

    void OnStateChanged() {
        try { _ = InvokeAsync(StateHasChanged); }
        catch { }
    }

    // ── Rescan (same folders, clears results and restarts)
    void Rescan() {
        _flagged.Clear();
        _deleted.Clear();
        Scan.StartScanAndCompare();
        Nav.NavigateTo("/");
    }

    // ── Safety
    void ToggleSafety() {
        if (_safetyOn) _showRawModal = true;
        else { _safetyOn = true; }
    }
    void GoRaw() { _safetyOn = false; _showRawModal = false; }

    // ── Flag / unflag
    void ToggleFlag(DuplicateItem item) {
        if (_deleted.Contains(item.Path)) return;
        if (!_flagged.Remove(item.Path)) _flagged.Add(item.Path);
    }

    // ── Per-file delete (recycle bin)
    void DeleteSingle(DuplicateItem item) {
        var (deleted, _, errors) = Scan.DeleteItems(new[] { item }, permanent: false, removeFromResults: !_greyOutOnDelete);
        if (deleted > 0) {
            _deleted.Add(item.Path);
            _flagged.Remove(item.Path);
        } else {
            ShowMsg("Failed to delete: " + string.Join("; ", errors), true);
        }
    }

    // ── Delete flagged in one group
    async Task DeleteFlaggedInGroup(List<DuplicateItem> flaggedItems) {
        if (flaggedItems.Count == 0) return;
        if (_safetyOn) {
            bool ok = await JS.InvokeAsync<bool>("confirm", $"Send {flaggedItems.Count} flagged file(s) to the Recycle Bin?");
            if (!ok) return;
        }
        var (deleted, failed, errors) = Scan.DeleteItems(flaggedItems, permanent: false, removeFromResults: !_greyOutOnDelete);
        foreach (var item in flaggedItems) { _deleted.Add(item.Path); _flagged.Remove(item.Path); }
        if (failed > 0) ShowMsg($"{deleted} deleted, {failed} failed: {string.Join("; ", errors.Take(3))}", true);
    }

    // ── Delete all flagged across all groups
    async Task DeleteAllFlagged() {
        var toDelete = Scan.Duplicates.Where(d => _flagged.Contains(d.Path) && !_deleted.Contains(d.Path)).ToList();
        if (toDelete.Count == 0) return;
        if (_safetyOn) {
            bool ok = await JS.InvokeAsync<bool>("confirm", $"Send {toDelete.Count} flagged file(s) to the Recycle Bin?");
            if (!ok) return;
        }
        var (deleted, failed, errors) = Scan.DeleteItems(toDelete, permanent: false, removeFromResults: !_greyOutOnDelete);
        foreach (var item in toDelete) { _deleted.Add(item.Path); _flagged.Remove(item.Path); }
        if (failed > 0) ShowMsg($"{deleted} deleted, {failed} failed: {string.Join("; ", errors.Take(3))}", true);
        else ShowMsg($"{deleted} file(s) sent to Recycle Bin.", false);
    }

    // ── Complete and clear (removes from results list, doesn't touch files)
    void CompleteCard(List<DuplicateItem> items, Guid groupId) {
        Scan.RemoveFromResults(items);
        foreach (var item in items) { _flagged.Remove(item.Path); _deleted.Remove(item.Path); }
    }

    // ── Per-group dropdown toggle
    void ToggleGroupDropdown(Guid id) {
        _openGroupDropdown = _openGroupDropdown == id ? Guid.Empty : id;
        _autoSelectOpen = false;
    }

    // ── Column order: sort within group by include folder order (main = leftmost)
    int FolderOrder(DuplicateItem item) {
        var folders = Scan.OrderedIncludeList;
        for (int fi = 0; fi < folders.Count; fi++) {
            var norm = folders[fi].TrimEnd('\\', '/') + Path.DirectorySeparatorChar;
            if (item.Path.StartsWith(norm, StringComparison.OrdinalIgnoreCase))
                return fi;
        }
        return int.MaxValue;
    }

    // ── Per-group smart flag helpers
    void ClearGroupSelection(List<DuplicateItem> items) {
        foreach (var item in items) _flagged.Remove(item.Path);
        _openGroupDropdown = Guid.Empty;
    }
    void FlagLowestRes(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var min = items.Min(i => i.FrameSizeInt);
        foreach (var i in items.Where(x => x.FrameSizeInt == min && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagHighestRes(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var max = items.Max(i => i.FrameSizeInt);
        foreach (var i in items.Where(x => x.FrameSizeInt == max && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagSmallest(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var min = items.Min(i => i.SizeLong);
        foreach (var i in items.Where(x => x.SizeLong == min && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagLargest(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var max = items.Max(i => i.SizeLong);
        foreach (var i in items.Where(x => x.SizeLong == max && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagShortest(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var min = items.Min(i => i.Duration);
        foreach (var i in items.Where(x => x.Duration == min && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagLongest(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        var max = items.Max(i => i.Duration);
        foreach (var i in items.Where(x => x.Duration == max && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }
    void FlagNoAudio(List<DuplicateItem> items) {
        ClearGroupSelection(items);
        foreach (var i in items.Where(x => !x.IsImage && string.IsNullOrEmpty(x.AudioFormat) && !_deleted.Contains(x.Path)))
            _flagged.Add(i.Path);
    }

    // ── Clear resolved groups (only 1 file left — duplicates already deleted)
    void ClearResolved() {
        var resolved = Scan.Duplicates
            .GroupBy(d => d.GroupId)
            .Where(g => g.Count(i => !_deleted.Contains(i.Path)) <= 1)
            .SelectMany(g => g)
            .ToList();
        Scan.RemoveFromResults(resolved);
        foreach (var item in resolved) { _flagged.Remove(item.Path); _deleted.Remove(item.Path); }
    }

    // ── Global smart select (existing logic preserved)
    void ClearSelection() { _autoSelectOpen = false; _flagged.Clear(); }
    void SelectNoAudio() {
        _autoSelectOpen = false;
        _flagged.Clear();
        foreach (var item in Scan.Duplicates.Where(d => !d.IsImage && string.IsNullOrEmpty(d.AudioFormat) && !_deleted.Contains(d.Path)))
            _flagged.Add(item.Path);
    }
    void InvertSelection() {
        _autoSelectOpen = false;
        foreach (var item in Scan.Duplicates.Where(d => !_deleted.Contains(d.Path))) {
            if (!_flagged.Remove(item.Path)) _flagged.Add(item.Path);
        }
    }

    enum AutoSelectMode { LowestQuality, SmallestFile, Oldest, Newest, HundredPercentEqual }

    void AutoSelect(AutoSelectMode mode) {
        _autoSelectOpen = false;
        _flagged.Clear();
        var all = Scan.Duplicates;
        var processed = new HashSet<Guid>();

        if (mode == AutoSelectMode.HundredPercentEqual) {
            foreach (var grp in all.GroupBy(d => d.GroupId)) {
                var items = grp.ToList();
                if (items.All(i => i.Similarity >= 100f))
                    for (int i = 1; i < items.Count; i++) _flagged.Add(items[i].Path);
            }
            return;
        }

        foreach (var first in all) {
            if (processed.Contains(first.GroupId)) continue;
            var groupItems = all.Where(d => d.GroupId == first.GroupId).ToList();
            if (groupItems.Count < 2) { processed.Add(first.GroupId); continue; }

            DuplicateItem keeper = mode switch {
                AutoSelectMode.LowestQuality => PickHighestQuality(groupItems),
                AutoSelectMode.SmallestFile  => groupItems.OrderByDescending(d => d.SizeLong).First(),
                AutoSelectMode.Oldest        => groupItems.OrderByDescending(d => d.DateCreated).First(),
                AutoSelectMode.Newest        => groupItems.OrderBy(d => d.DateCreated).First(),
                _                            => groupItems[0]
            };

            foreach (var item in groupItems)
                if (item.Path != keeper.Path && !_deleted.Contains(item.Path))
                    _flagged.Add(item.Path);

            processed.Add(first.GroupId);
        }
    }

    static DuplicateItem PickHighestQuality(List<DuplicateItem> items) {
        string[] criteria = { "Duration", "Resolution", "Bitrate", "FPS", "Audio Bitrate" };
        var keep = items[0];
        bool anyApplied = false;
        string? lastCriterion = null;
        foreach (var criterion in criteria) {
            if (criterion is "Duration" or "FPS" or "Bitrate" or "Audio Bitrate" && keep.IsImage) continue;
            bool tieOnLast = anyApplied && HasTie(lastCriterion!, items, keep);
            if (!anyApplied || tieOnLast) { keep = ApplyCriterion(criterion, items); anyApplied = true; lastCriterion = criterion; }
        }
        return keep;
    }
    static bool HasTie(string criterion, List<DuplicateItem> items, DuplicateItem keep) => criterion switch {
        "Duration"      => items.Count(d => d.Duration == keep.Duration) > 1,
        "Resolution"    => items.Count(d => d.FrameSizeInt == keep.FrameSizeInt) > 1,
        "FPS"           => items.Count(d => d.Fps == keep.Fps) > 1,
        "Bitrate"       => items.Count(d => d.BitRateKbs == keep.BitRateKbs) > 1,
        "Audio Bitrate" => items.Count(d => d.AudioSampleRate == keep.AudioSampleRate) > 1,
        _               => false
    };
    static DuplicateItem ApplyCriterion(string criterion, List<DuplicateItem> items) => criterion switch {
        "Duration"      => items.OrderByDescending(d => d.Duration).First(),
        "Resolution"    => items.OrderByDescending(d => d.FrameSizeInt).First(),
        "FPS"           => items.OrderByDescending(d => d.Fps).First(),
        "Bitrate"       => items.OrderByDescending(d => d.BitRateKbs).First(),
        "Audio Bitrate" => items.OrderByDescending(d => d.AudioSampleRate).First(),
        _               => items[0]
    };

    // ── Color pairing
    string PairClass<T>(T value, List<T> allValues) where T : notnull {
        // Build ordered list of distinct values in order of first appearance
        var seen = new Dictionary<T, int>();
        int pairIndex = 0;
        foreach (var v in allValues) {
            if (!seen.ContainsKey(v)) seen[v] = pairIndex++;
        }
        // Count how many items share this value
        int count = allValues.Count(v => EqualityComparer<T>.Default.Equals(v, value));
        if (count <= 1) return "c-unique";
        int idx = seen[value];
        return idx switch {
            0 => "c-pair-1",
            1 => "c-pair-2",
            _ => "c-pair-3"
        };
    }

    // ── Formatters
    static string FormatDuration(TimeSpan t) =>
        t.TotalHours >= 1
            ? $"{(int)t.TotalHours} hr {t.Minutes} mins {t.Seconds} secs"
            : t.TotalMinutes >= 1
                ? $"{t.Minutes} mins {t.Seconds} secs"
                : $"{t.Seconds} secs";

    static string FormatSize(long bytes) {
        if (bytes <= 0) return "0 B";
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    void ShowMsg(string msg, bool failed) {
        _operationMsg = msg; _operationFailed = failed;
        _ = Task.Delay(5000).ContinueWith(_ => InvokeAsync(() => { _operationMsg = null; StateHasChanged(); }));
    }

    // ── Context menu (preserved for right-click path copy)
    bool _menuVisible;
    double _menuX, _menuY;
    DuplicateItem? _menuItem;
    List<DuplicateItem>? _menuGroup;

    public void Dispose() => Scan.StateChanged -= OnStateChanged;
}
